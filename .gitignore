# build output
/dist
/release

# dependencies
/node_modules
npm-debug.log*

# editor
.idea/
.vscode/

# python engine
engine/.venv/
engine/runtime/
engine/bin/
engine/**/__pycache__/

# RTX Video runtime: NVIDIA's feature DLLs (nvngx_*.dll) are non-redistributable and the bridge
# (rtxvideo_cuda.dll) is locally built; the whole folder is local-only (see engine/rtxvideo.py).
engine/rtxvideo/
engine/GMFSS_Fortuna/vid_out/

# tensorrt engine cache + export artifacts (machine specific, built on first run)
engine/trt_cache/
engine/*.onnx
engine/*.onnx.data
engine/*.engine

# large model weights (download separately, see README)
engine/GMFSS_Fortuna/train_log/

# generated video outputs / scratch
*.mp4
# ...but keep sample source clips, e.g. samples/gtest.mp4 (the 24fps example)
!samples/*.mp4
# ...while still ignoring generated interpolation outputs in samples (e.g. *_48fps.mp4)
samples/*fps.mp4
