# build output
/dist
/release

# dependencies
/node_modules
npm-debug.log*

# editor
.idea/
.vscode/

# engine: generated, fetched, and non-redistributable files kept out of git (caches, the Python runtime, ffmpeg, NVIDIA DLLs)
engine/**/__pycache__/
engine/bin/
engine/rtxvideo/nvngx_truehdr.dll
engine/rtxvideo/nvngx_vsr.dll
engine/rtxvideo/build_src/*.obj
engine/rtxvideo/build_src/*.lib
engine/rtxvideo/build_src/*.exp
engine/rtxvideo/build_src/rtxvideo_cuda.dll
engine/runtime/
engine/trt_cache/
engine/dvtools/
engine/hptools/

# ...but keep sample source clips, e.g. samples/test.mp4 (the 24fps example)
!samples/*.mp4
# ...while still ignoring generated interpolation outputs in samples (e.g. *_48fps.mp4)
samples/*fps*.mp4
